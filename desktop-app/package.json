{
  "name": "ai-learning-world-explore",
  "version": "1.0.0",
  "description": "AI学习世界探索版 - Minecraft风格3D体素探索学习游戏",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.ailearningworld.explore",
    "productName": "AI学习世界-探索版",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "game/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI学习世界-探索版"
    }
  },
  "author": "GingerYang19",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
